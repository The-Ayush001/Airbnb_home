<%- include('../../partials/head.ejs') %>
</head>
<body class="bg-black">
  <%- include('../../partials/nav.ejs') %>
  <main class="container mx-auto bg-gray-800 shadow-xl rounded-2xl p-10 mt-12 max-w-4xl">
    <h1 class="text-5xl text-gray-100 font-bold text-center mb-8">Hey Host! Here are your homes.</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <% registeredHomes.forEach(home => { %>
      <div class="bg-gray-200 rounded-xl overflow-hidden shadow-lg hover:shadow-xl transition-all duration-300">
        <img src="<%= home.PhotoURL %>" alt="<%= home.homeName %>" class="w-full h-60 object-cover">
        <div class="px-6 py-2">
        <h2 class="text-2xl font-bold text-gray-800 mb-2"><%= home.homeName %></h2>
        <div class="space-y-2">
          <p class="text-red-500 text-xl font-semibold">₹<%= home.Price %> / night</p>
          <p class=" relative text-gray-600">
          <i class="fas fa-map-marker-alt mr-2"></i>
          <%= home.Location %>
        </p>
          <div class="flex items-center">
          <i class="fas fa-star text-yellow-400 mr-1"></i>
          <span class="text-gray-700"><span class="text-yellow-400 text-xl">★</span><%= home.Rating %>/5</span>
          </div>
          <div class="flex gap-2">
            <a href="/host/edit-home/<%= home.id%>?editing=true" class="  text-lg bg-blue-500 hover:bg-blue-600 px-2 py-1 rounded-lg text-white font-semibold">Edit</a>
            <form action="/host/delete-home/<%= home.id %>" method="POST">
              <button type="submit" class="text-lg bg-red-500 hover:bg-red-600 px-2 py-1 rounded-lg text-white font-semibold">Delete</button>
            </form>
          </div>
        </div>
      </div>
    </div>
      <% }) %>
    </div>
  </main>
</body>
</html>